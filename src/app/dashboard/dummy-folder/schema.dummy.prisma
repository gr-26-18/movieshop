generator client {
  provider = "prisma-client"
  output   = "../../../generated/prisma-dashboard"
}

datasource db {
  provider = "sqlite"
}


// this is added
enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// this is added
model Movie {
  id          String      @id @default(cuid())
  title       String
  price       Float
  imageUrl    String?
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

// this is added
model Order {
  id              String      @id @default(cuid())
  userId          String
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  orderDate       DateTime    @default(now())
  shippingCity    String
  shippingCountry String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]
}

// this is added
model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  movieId  String
  quantity Int
  price    Float
  order    Order  @relation(fields: [orderId], references: [id])
  movie    Movie  @relation(fields: [movieId], references: [id])
}

