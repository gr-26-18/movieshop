
# MovieShop Environment Variables

# Copy this file to .env and fill in the values.
# NEVER commit the .env file to git! It contains secrets.



# DATABASE — PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/movieshop"

# BETTER AUTH — Authentication configuration
BETTER_AUTH_SECRET="your-secret-key-here-change-this"

# BETTER_AUTH_URL: The base URL of your application.
BETTER_AUTH_URL="http://localhost:3000"

# NEXT.JS — Public environment variables (accessible in the browser)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
