// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


// ======================================================================
// MOVIE & CATALOG MODELS
// ======================================================================
model Movie {

  id          String        @id @default(cuid())
  title       String        
  description String        
  price       Int        
  releaseDate DateTime      
  imageUrl    String?       
  stock       Int           @default(0) 
  runtime     Int?          
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relationships
  genres      Genre[]      
  credits     MovieCredit[] 
  orderItems  OrderItem[]   

}

model Genre {
  id          String   @id @default(cuid())
  name        String   @unique 
  description String?          

  // Relationships
  movies      Movie[]  //genre contains a list of movies.
}



// Model to manage information about directors and actors 
model Person {
  id          String   @id @default(cuid())
  name        String
  bio         String?

  // Relationships
  credits     MovieCredit[] //This person has a list of movies they have worked on
}

// Explicit join table to associate a Person with a Movie in a specific role 
enum CreditRole {
  DIRECTOR
  ACTOR
}
model MovieCredit {
  id        String     @id @default(cuid())
  movieId   String
  personId  String
  role      CreditRole // Differentiates if they directed or acted 

  movie     Movie      @relation(fields: [movieId], references: [id], onDelete: Cascade)
  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([movieId, personId, role])
}


// =================================================================
// E-COMMERCE MODELS
// ==================================================================

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Order {
  id          String      @id @default(cuid())
  userId      String      // Reference to Better Auth user 
  totalAmount Int      
  status      OrderStatus @default(PENDING) 
  orderDate   DateTime    @default(now())     

  // Relationships
  orderItems  OrderItem[]
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String   
  movieId         String  
  quantity        Int      
  priceAtPurchase Int    

  // Relationships
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  movie           Movie    @relation(fields: [movieId], references: [id])
}



